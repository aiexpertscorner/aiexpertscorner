---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolCard from "../../../components/cards/ToolCard.astro";
import Breadcrumbs from "../../../components/site/Breadcrumbs.astro";
import CategoryHero from "../../../components/site/CategoryHero.astro";
import "../../../styles/category-detail.css";

import categoryMapRaw from "../../../data/build/category-map.json";
import toolMapRaw from "../../../data/build/tool-map.json";

type Tool = {
  handle: string;
  name: string;
  url: string;
  short?: string;
  desc?: string;
  cat?: string;
  catSlug?: string;
  pricing?: string;
  tags?: string[];
  e?: string;
};

type CategoryEntry = {
  slug: string;
  name: string;
  toolHandles: string[];
  toolCount?: number;
};

const categoryMap = categoryMapRaw as Record<string, CategoryEntry>;
const toolMap = toolMapRaw as Record<string, Tool>;

export async function getStaticPaths() {
  const categoryPathsModule = await import("../../../data/build/category-paths.json");
  const categoryPaths = categoryPathsModule.default as string[];

  return categoryPaths.map((slug) => ({
    params: { slug }
  }));
}

const { slug } = Astro.params as { slug: string };

if (!slug || !categoryMap[slug]) {
  throw new Error(`Category not found for slug: ${slug}`);
}

const category = categoryMap[slug];

const categoryTools = category.toolHandles
  .map((handle) => toolMap[handle])
  .filter(Boolean) as Tool[];

const pageTitle = `${category.name} AI Tools — AI Experts Corner`;
const pageDescription = `Browse ${categoryTools.length.toLocaleString()} ${category.name} AI tools. Compare tools, pricing and categories in the AI Experts Corner directory.`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${category.name} AI Tools`,
  description: pageDescription,
  url: `https://aiexpertscorner.com/tools/category/${slug}`,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: categoryTools.length
  }
};

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Tools", href: "/tools" },
  { label: category.name }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={`https://aiexpertscorner.com/tools/category/${slug}`} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <section class="section">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />
      <CategoryHero category={category.name} toolCount={categoryTools.length} />
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{category.name} tools</h2>
          <p>Explore every tool currently mapped to this category.</p>
        </div>

        <a href="/tools" class="section-link">Back to all tools</a>
      </div>

      <div class="grid-tools">
        {categoryTools.map((tool) => (
          <ToolCard tool={tool} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>