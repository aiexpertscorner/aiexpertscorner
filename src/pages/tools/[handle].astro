---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/site/Breadcrumbs.astro";
import ToolHero from "../../components/site/ToolHero.astro";
import ToolQuickFacts from "../../components/site/ToolQuickFacts.astro";
import ToolCard from "../../components/cards/ToolCard.astro";
import "../../styles/tool-detail.css";

import toolMapRaw from "../../data/build/tool-map.json";
import relatedMapRaw from "../../data/build/related-map.json";

// types
type Tool = {
  handle: string;
  name: string;
  url: string;
  short?: string;
  desc?: string;
  cat?: string;
  catSlug?: string;
  pricing?: string;
  tags?: string[];
  e?: string;
};

const toolMap = toolMapRaw as Record<string, Tool>;
const relatedMap = relatedMapRaw as Record<string, string[]>;

const slugify = (value: string) =>
  value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");

// Astro behandelt getStaticPaths in eigen scope.
// Daarom importeren we de paths HIER opnieuw.
export async function getStaticPaths() {
  const toolPathsModule = await import("../../data/build/tool-paths.json");
  const toolPaths = toolPathsModule.default as string[];

  return toolPaths.map((handle) => ({
    params: { handle }
  }));
}

const { handle } = Astro.params as { handle: string };

if (!handle || !toolMap[handle]) {
  throw new Error(`Tool not found for handle: ${handle}`);
}

const tool = toolMap[handle];
const categorySlug = tool.catSlug || (tool.cat ? slugify(tool.cat) : undefined);

const relatedHandles = relatedMap[handle] || [];
const relatedTools = relatedHandles
  .map((relatedHandle) => toolMap[relatedHandle])
  .filter(Boolean) as Tool[];

const pageTitle = `${tool.name} — AI Tool Review & Overview`;
const pageDescription =
  tool.short ||
  tool.desc ||
  `${tool.name} is listed on AI Experts Corner. Explore pricing, category, features and similar alternatives.`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: tool.name,
  applicationCategory: tool.cat || "AI Tool",
  operatingSystem: "Web",
  description: tool.short || tool.desc || "",
  url: `https://aiexpertscorner.com/tools/${tool.handle}`,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    category: tool.pricing || "Unknown"
  }
};

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Tools", href: "/tools" },
  ...(tool.cat && categorySlug
    ? [{ label: tool.cat, href: `/tools/category/${categorySlug}` }]
    : []),
  { label: tool.name }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <link rel="canonical" href={`https://aiexpertscorner.com/tools/${tool.handle}`} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <section class="section">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />

      <div class="tool-detail-layout">
        <ToolHero
          tool={tool}
          categoryHref={categorySlug ? `/tools/category/${categorySlug}` : undefined}
        />
        <ToolQuickFacts tool={tool} />
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container tool-detail-content">
      <div class="content-card">
        <h2>Overview</h2>
        <p>
          {tool.name} is part of the AI Experts Corner directory. This page helps users quickly understand
          what the tool does, how it is categorized, and whether it may fit their workflow.
        </p>
        <p>
          {tool.desc || tool.short || `${tool.name} is an AI tool listed in our directory.`}
        </p>
      </div>

      <div class="content-card">
        <h2>Who should use {tool.name}?</h2>
        <p>
          {tool.name} may be relevant for users looking for tools in the
          <strong> {tool.cat || "AI tools"} </strong>
          category.
        </p>
        <p>
          Browse the category page to compare alternatives, or continue exploring similar tools below.
        </p>
      </div>
    </div>
  </section>

  {relatedTools.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <div>
            <h2>Similar tools</h2>
            <p>More tools in the same category.</p>
          </div>

          {tool.cat && categorySlug && (
            <a
              href={`/tools/category/${categorySlug}`}
              class="section-link"
            >
              View category
            </a>
          )}
        </div>

        <div class="grid-tools">
          {relatedTools.map((related) => (
            <ToolCard tool={related} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>