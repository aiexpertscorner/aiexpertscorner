---
interface Props {
  totalTools: number;
  categories: string[];
  catCounts: Record<string, number>;
  pricingCounts: {
    all: number;
    free: number;
    freemium: number;
    paid: number;
    unknown: number;
  };
}

const { totalTools, categories, catCounts, pricingCounts } = Astro.props;
---

<aside class="tools-sidebar">
  <div class="tools-panel">
    <div class="tools-panel__head">
      <h3>Filters</h3>
      <button id="filters-reset" type="button">Reset</button>
    </div>

    <div class="tools-filter-group">
      <label for="category-filter">Category</label>
      <select id="category-filter">
        <option value="all">All categories ({totalTools.toLocaleString()})</option>
        {categories.map((cat) => (
          <option value={cat}>{cat} ({(catCounts[cat] || 0).toLocaleString()})</option>
        ))}
      </select>
    </div>

    <div class="tools-filter-group">
      <label for="pricing-filter">Pricing</label>
      <select id="pricing-filter">
        <option value="all">All pricing ({pricingCounts.all.toLocaleString()})</option>
        <option value="free">Free ({pricingCounts.free.toLocaleString()})</option>
        <option value="freemium">Freemium ({pricingCounts.freemium.toLocaleString()})</option>
        <option value="paid">Paid ({pricingCounts.paid.toLocaleString()})</option>
        <option value="unknown">Unknown ({pricingCounts.unknown.toLocaleString()})</option>
      </select>
    </div>

    <div class="tools-filter-group">
      <label for="sort-filter">Sort by</label>
      <select id="sort-filter">
        <option value="relevance">Relevance</option>
        <option value="name-asc">Name A–Z</option>
        <option value="name-desc">Name Z–A</option>
        <option value="free-first">Free first</option>
        <option value="newest">Newest first</option>
        <option value="oldest">Oldest first</option>
      </select>
    </div>

    <div class="tools-filter-group">
      <label for="per-page-filter">Results per page</label>
      <select id="per-page-filter">
        <option value="24">24</option>
        <option value="36" selected>36</option>
        <option value="48">48</option>
        <option value="60">60</option>
      </select>
    </div>

    <div class="tools-quick-chips">
      <button type="button" class="quick-chip" data-pricing-chip="free">Free tools</button>
      <button type="button" class="quick-chip" data-pricing-chip="freemium">Freemium</button>
      <button type="button" class="quick-chip" data-category-chip="AI Agents">AI Agents</button>
      <button type="button" class="quick-chip" data-category-chip="SEO & Marketing">SEO & Marketing</button>
    </div>
  </div>
</aside>